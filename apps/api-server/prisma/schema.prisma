generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum PublishStatus {
  draft
  published
  archived
}

enum PayerType {
  individu
  korporat
  majikan_spg
}

enum PayerStatus {
  active
  inactive
  suspended
  merged
}

enum IdentityType {
  mykad
  passport
  ssm
  tax
  other
}

enum DeductionMode {
  fixed
  percent
}

enum DuplicateSource {
  spg_import
  manual
}

enum DuplicateCaseStatus {
  open
  reviewed
  merged
  rejected
}

enum BlacklistAction {
  add
  remove
  update
}

enum SpgPayrollPaymentChannel {
  FPX_B2B
  CARD
  CHEQUE
  COUNTER_CASH
}

enum SpgPayrollBatchStatus {
  draft_preview
  awaiting_online_payment
  pending_payment
  paid_success
  paid_failed
  cancelled
}

enum GuestPaymentSource {
  ONLINE_GUEST
  COUNTER_COLLECTION
  CORPORATE_DIRECT
  SPG
}

enum CounterPaymentChannel {
  COUNTER_CASH
  COUNTER_CARD_TERMINAL
  COUNTER_CHEQUE
  COUNTER_DEBIT
  COUNTER_QR
}

enum CounterReconStatus {
  unbatched
  batched
  reconciled
  exception
}

enum CounterDepositType {
  CASH_BANKIN
  CARD_SETTLEMENT
}

enum CounterDepositStatus {
  draft
  submitted
  matched
  variance
  reconciled
  cancelled
}

enum BankStatementMatchStatus {
  unmatched
  auto_matched
  manual_matched
  ignored
}

enum ReconciliationCaseType {
  unmatched_statement_line
  unmatched_deposit_batch
  amount_mismatch
  bank_fee
  reversal
}

enum ReconciliationCaseStatus {
  open
  investigating
  resolved
  rejected
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String
  name         String
  photoUrl     String?
  role         String    @default("admin")
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
  duplicateCasesDetected  DuplicateCase[]
  mergeExecutions         MergeExecution[]
  statusChanges           PayerStatusHistory[]
  blacklistChanges        PayerBlacklistHistory[]
  profileAuditsPerformed  AuditLogProfile[]
  spgPayrollStatusChanges SpgPayrollStatusHistory[]
  counterCollectedPayments GuestPayment[]           @relation("CounterCollectedPayments")
  counterCreatedBatches    CounterDepositBatch[]    @relation("CounterBatchCreatedBy")
  counterApprovedBatches   CounterDepositBatch[]    @relation("CounterBatchApprovedBy")
  bankStatementImports     BankStatementImport[]    @relation("BankStatementUploadedBy")
  reconciliationAssigned   ReconciliationCase[]     @relation("ReconciliationAssignedTo")
  reconciliationResolved   ReconciliationCase[]     @relation("ReconciliationResolvedBy")
  counterStatusChanges     CounterStatusHistory[]
  scheduledPaymentsCancelled ScheduledPayment[]   @relation("ScheduledPaymentCancelledBy")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String   @default("")
  permissions String   @default("[]") @db.VarChar(5000)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Session {
  id        Int      @id @default(autoincrement())
  userId    Int
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Post {
  id              Int           @id @default(autoincrement())
  title           String
  slug            String        @unique
  excerpt         String?       @db.Text
  content         String        @db.LongText
  status          PublishStatus @default(draft)
  featuredImageId Int?
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  featuredImage   Media?        @relation(fields: [featuredImageId], references: [id], onDelete: SetNull)
  categories      Category[]

  @@index([status])
  @@index([createdAt])
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  posts       Post[]

  @@index([createdAt])
}

model Page {
  id              Int           @id @default(autoincrement())
  title           String
  slug            String        @unique
  content         String        @db.LongText
  status          PublishStatus @default(draft)
  featuredImageId Int?
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  featuredImage   Media?        @relation(fields: [featuredImageId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
}

model Media {
  id           Int      @id @default(autoincrement())
  filename     String
  originalName String
  title        String?
  caption      String?  @db.Text
  description  String?  @db.Text
  mimeType     String
  size         Int
  width        Int?
  height       Int?
  altText      String?
  path         String
  url          String
  createdAt    DateTime @default(now())
  posts        Post[]
  pages        Page[]

  @@index([createdAt])
}

model Setting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model PayerProfile {
  id                 Int                     @id @default(autoincrement())
  payerCode          String                  @unique
  payerType          PayerType
  displayName        String
  identityNo         String?
  identityType       IdentityType?
  email              String?
  phone              String?
  passwordHash       String?
  status             PayerStatus             @default(active)
  isBlacklisted      Boolean                 @default(false)
  blacklistReason    String?                 @db.Text
  blacklistFrom      DateTime?
  blacklistTo        DateTime?
  mergedIntoPayerId  Int?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  mergedInto         PayerProfile?           @relation("PayerMergeRelation", fields: [mergedIntoPayerId], references: [id], onDelete: SetNull)
  mergedChildren     PayerProfile[]          @relation("PayerMergeRelation")
  individual         PayerIndividual?
  corporate          PayerCorporate?
  spgEmployer        SpgEmployer?
  spgEmployees       SpgEmployee[]           @relation("EmployerEmployees")
  linkedEmployee     SpgEmployee[]           @relation("LinkedIndividual")
  addresses          PayerAddress[]
  contactPersons     PayerContactPerson[]
  branches           CorporateBranch[]
  shareholders       CorporateShareholder[]
  documents          PayerDocument[]
  duplicateMatches   DuplicateMatch[]        @relation("CandidatePayer")
  mergeMasterRecords MergeExecution[]        @relation("MergeMaster")
  mergeMergedRecords MergeExecution[]        @relation("MergeMerged")
  statusHistory      PayerStatusHistory[]
  blacklistHistory   PayerBlacklistHistory[]
  auditLogs          AuditLogProfile[]       @relation("AuditTargetPayer")
  spgPayrollBatches  SpgPayrollBatch[]

  @@unique([identityType, identityNo])
  @@index([payerType])
  @@index([status])
  @@index([createdAt])
}

model PayerIndividual {
  payerId           Int          @id
  fullName          String
  mykadOrPassport   String       @unique
  dob               DateTime?
  gender            String?
  maritalStatus     String?
  occupation        String?
  incomeSource      String?
  monthlyIncome     Decimal?     @db.Decimal(18, 2)
  payer             PayerProfile @relation(fields: [payerId], references: [id], onDelete: Cascade)

  @@index([fullName])
}

model PayerCorporate {
  payerId      Int          @id
  companyName  String
  ssmNo        String       @unique
  companyType  String?
  taxNo        String?
  taxBranch    String?
  payer        PayerProfile @relation(fields: [payerId], references: [id], onDelete: Cascade)

  @@index([companyName])
}

model SpgEmployer {
  payerId                 Int           @id
  agreementNo             String?
  agreementEffectiveDate  DateTime?
  agreementExpiryDate     DateTime?
  deductionMode           DeductionMode?
  deductionValue          Decimal?      @db.Decimal(18, 2)
  deductionCap            Decimal?      @db.Decimal(18, 2)
  payer                   PayerProfile  @relation(fields: [payerId], references: [id], onDelete: Cascade)
}

model SpgEmployee {
  id                      Int           @id @default(autoincrement())
  employerPayerId         Int
  employeeIdentityNo      String
  employeeName            String
  employeeEmail           String?
  employeePhone           String?
  deductionAmount         Decimal?      @db.Decimal(18, 2)
  employmentStatus        String?
  linkedIndividualPayerId Int?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  employer                PayerProfile  @relation("EmployerEmployees", fields: [employerPayerId], references: [id], onDelete: Cascade)
  linkedIndividual        PayerProfile? @relation("LinkedIndividual", fields: [linkedIndividualPayerId], references: [id], onDelete: SetNull)
  duplicateMatches        DuplicateMatch[]

  @@index([employerPayerId])
  @@index([employeeIdentityNo])
}

model PayerAddress {
  id          Int          @id @default(autoincrement())
  payerId     Int
  addressType String
  line1       String
  line2       String?
  city        String?
  state       String?
  postcode    String?
  country     String?
  isPrimary   Boolean      @default(false)
  payer       PayerProfile @relation(fields: [payerId], references: [id], onDelete: Cascade)

  @@index([payerId])
}

model PayerContactPerson {
  id           Int          @id @default(autoincrement())
  payerId      Int
  name         String
  icNo         String?
  position     String?
  email        String?
  phone        String?
  isAuthorized Boolean      @default(false)
  payer        PayerProfile @relation(fields: [payerId], references: [id], onDelete: Cascade)

  @@index([payerId])
}

model CorporateBranch {
  id        Int          @id @default(autoincrement())
  payerId   Int
  branchName String
  line1     String?
  line2     String?
  city      String?
  state     String?
  postcode  String?
  country   String?
  payer     PayerProfile @relation(fields: [payerId], references: [id], onDelete: Cascade)

  @@index([payerId])
}

model CorporateShareholder {
  id               Int          @id @default(autoincrement())
  payerId          Int
  name             String
  ownershipPercent Decimal?     @db.Decimal(5, 2)
  payer            PayerProfile @relation(fields: [payerId], references: [id], onDelete: Cascade)

  @@index([payerId])
}

model PayerDocument {
  id         Int          @id @default(autoincrement())
  payerId    Int
  docType    String
  docNo      String?
  fileUrl    String?
  verifiedAt DateTime?
  verifiedBy String?
  payer      PayerProfile @relation(fields: [payerId], references: [id], onDelete: Cascade)

  @@index([payerId])
}

model DuplicateCase {
  id          Int                 @id @default(autoincrement())
  source      DuplicateSource
  status      DuplicateCaseStatus @default(open)
  detectedAt  DateTime            @default(now())
  detectedBy  Int?
  notes       String?             @db.Text
  detectedByUser User?            @relation(fields: [detectedBy], references: [id], onDelete: SetNull)
  matches     DuplicateMatch[]

  @@index([status, detectedAt])
}

model DuplicateMatch {
  id                  Int           @id @default(autoincrement())
  caseId              Int
  candidatePayerId    Int
  matchedSpgEmployeeId Int
  matchScore          Decimal       @db.Decimal(5, 2)
  matchReasonJson     Json?
  duplicateCase       DuplicateCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  candidatePayer      PayerProfile  @relation("CandidatePayer", fields: [candidatePayerId], references: [id], onDelete: Cascade)
  matchedSpgEmployee  SpgEmployee   @relation(fields: [matchedSpgEmployeeId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([candidatePayerId])
}

model MergeExecution {
  id                    Int          @id @default(autoincrement())
  masterPayerId         Int
  mergedPayerId         Int
  executedBy            Int
  executedAt            DateTime     @default(now())
  conflictResolutionJson Json?
  summaryJson           Json?
  masterPayer           PayerProfile @relation("MergeMaster", fields: [masterPayerId], references: [id], onDelete: Cascade)
  mergedPayer           PayerProfile @relation("MergeMerged", fields: [mergedPayerId], references: [id], onDelete: Cascade)
  executedByUser        User         @relation(fields: [executedBy], references: [id], onDelete: Restrict)
}

model PayerStatusHistory {
  id        Int          @id @default(autoincrement())
  payerId   Int
  oldStatus PayerStatus?
  newStatus PayerStatus
  changedBy Int?
  changedAt DateTime     @default(now())
  reason    String?      @db.Text
  payer     PayerProfile @relation(fields: [payerId], references: [id], onDelete: Cascade)
  changedByUser User?         @relation(fields: [changedBy], references: [id], onDelete: SetNull)

  @@index([payerId, changedAt])
}

model PayerBlacklistHistory {
  id        Int             @id @default(autoincrement())
  payerId   Int
  action    BlacklistAction
  reason    String?         @db.Text
  fromDate  DateTime?
  toDate    DateTime?
  changedBy Int?
  changedAt DateTime        @default(now())
  payer     PayerProfile    @relation(fields: [payerId], references: [id], onDelete: Cascade)
  changedByUser User?         @relation(fields: [changedBy], references: [id], onDelete: SetNull)

  @@index([payerId, changedAt])
}

model AuditLogProfile {
  id              Int          @id @default(autoincrement())
  entityName      String
  entityId        String
  action          String
  targetPayerId   Int?
  oldValueJson    Json?
  newValueJson    Json?
  performedBy     Int?
  performedAt     DateTime     @default(now())
  ipAddress       String?
  targetPayer     PayerProfile? @relation("AuditTargetPayer", fields: [targetPayerId], references: [id], onDelete: SetNull)
  performedByUser User?        @relation(fields: [performedBy], references: [id], onDelete: SetNull)

  @@index([entityName, entityId])
  @@index([targetPayerId, performedAt])
}

model GuestPayment {
  id            Int      @id @default(autoincrement())
  receiptNo     String   @unique
  guestName     String
  identityNo    String
  email         String?
  amount        Decimal  @db.Decimal(18, 2)
  paymentMethod String
  status        String   @default("success")
  source        GuestPaymentSource @default(ONLINE_GUEST)
  counterChannel CounterPaymentChannel?
  collectedByUserId Int?
  collectionPoint String?
  terminalRrn   String?
  terminalAuthCode String?
  terminalTid   String?
  terminalMid   String?
  depositBatchId Int?
  reconStatus   CounterReconStatus @default(unbatched)
  notes         String?   @db.Text
  paidAt        DateTime @default(now())
  createdAt     DateTime @default(now())
  collectedByUser User? @relation("CounterCollectedPayments", fields: [collectedByUserId], references: [id], onDelete: SetNull)
  depositBatch CounterDepositBatch? @relation(fields: [depositBatchId], references: [id], onDelete: SetNull)
  zakatItems    GuestPaymentZakatItem[]

  @@index([identityNo, paidAt])
  @@index([status, paidAt])
  @@index([source, paidAt])
  @@index([reconStatus, paidAt])
  @@index([depositBatchId])
}

model GuestPaymentZakatItem {
  id            Int         @id @default(autoincrement())
  guestPaymentId Int
  zakatType     String
  financialYear String
  amount        Decimal     @db.Decimal(18, 2)
  createdAt     DateTime    @default(now())
  guestPayment  GuestPayment @relation(fields: [guestPaymentId], references: [id], onDelete: Cascade)

  @@index([guestPaymentId])
  @@index([zakatType, financialYear])
}

model CounterDepositBatch {
  id             Int                @id @default(autoincrement())
  referenceNo    String             @unique
  depositType    CounterDepositType
  status         CounterDepositStatus @default(draft)
  depositDate    DateTime
  bankInDate     DateTime?
  declaredAmount Decimal            @db.Decimal(18, 2)
  systemAmount   Decimal            @db.Decimal(18, 2)
  varianceAmount Decimal            @db.Decimal(18, 2) @default(0)
  collectionPoint String?
  createdBy      Int
  approvedBy     Int?
  approvedAt     DateTime?
  slipUrl        String?
  notes          String?            @db.Text
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  createdByUser  User               @relation("CounterBatchCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  approvedByUser User?              @relation("CounterBatchApprovedBy", fields: [approvedBy], references: [id], onDelete: SetNull)
  items          CounterDepositBatchItem[]
  guestPayments  GuestPayment[]
  statementLines BankStatementLine[]
  reconciliationCases ReconciliationCase[]
  statusHistory  CounterStatusHistory[]

  @@index([depositDate, status])
  @@index([depositType, status])
}

model CounterDepositBatchItem {
  id            Int                @id @default(autoincrement())
  batchId       Int
  guestPaymentId Int               @unique
  amount        Decimal            @db.Decimal(18, 2)
  createdAt     DateTime           @default(now())
  batch         CounterDepositBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
}

model BankStatementImport {
  id               Int                @id @default(autoincrement())
  bankAccountNo    String?
  statementDateFrom DateTime?
  statementDateTo  DateTime?
  fileName         String
  uploadedBy       Int?
  createdAt        DateTime           @default(now())
  uploadedByUser   User?              @relation("BankStatementUploadedBy", fields: [uploadedBy], references: [id], onDelete: SetNull)
  lines            BankStatementLine[]
}

model BankStatementLine {
  id             Int                    @id @default(autoincrement())
  importId       Int
  lineNo         Int
  txnDate        DateTime
  description    String
  referenceNo    String?
  debit          Decimal?               @db.Decimal(18, 2)
  credit         Decimal?               @db.Decimal(18, 2)
  netAmount      Decimal                @db.Decimal(18, 2)
  matchedBatchId Int?
  matchStatus    BankStatementMatchStatus @default(unmatched)
  createdAt      DateTime               @default(now())
  import         BankStatementImport    @relation(fields: [importId], references: [id], onDelete: Cascade)
  matchedBatch   CounterDepositBatch?   @relation(fields: [matchedBatchId], references: [id], onDelete: SetNull)
  reconciliationCases ReconciliationCase[]

  @@index([importId, txnDate])
  @@index([matchStatus])
}

model ReconciliationCase {
  id              Int                     @id @default(autoincrement())
  caseType        ReconciliationCaseType
  status          ReconciliationCaseStatus @default(open)
  batchId         Int?
  statementLineId Int?
  differenceAmount Decimal?               @db.Decimal(18, 2)
  reason          String?                 @db.Text
  assignedTo      Int?
  resolvedBy      Int?
  resolvedAt      DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  batch           CounterDepositBatch?    @relation(fields: [batchId], references: [id], onDelete: SetNull)
  statementLine   BankStatementLine?      @relation(fields: [statementLineId], references: [id], onDelete: SetNull)
  assignedToUser  User?                   @relation("ReconciliationAssignedTo", fields: [assignedTo], references: [id], onDelete: SetNull)
  resolvedByUser  User?                   @relation("ReconciliationResolvedBy", fields: [resolvedBy], references: [id], onDelete: SetNull)
  statusHistory   CounterStatusHistory[]

  @@index([status, createdAt])
}

model CounterStatusHistory {
  id           Int      @id @default(autoincrement())
  entityType   String
  entityId     Int
  oldStatus    String?
  newStatus    String
  changedBy    Int?
  changedAt    DateTime @default(now())
  reason       String?  @db.Text
  batchId      Int?
  reconciliationCaseId Int?
  changedByUser User?   @relation(fields: [changedBy], references: [id], onDelete: SetNull)
  batch        CounterDepositBatch? @relation(fields: [batchId], references: [id], onDelete: Cascade)
  reconciliationCase ReconciliationCase? @relation(fields: [reconciliationCaseId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId, changedAt])
}

enum ScheduledPaymentStatus {
  active
  paused
  completed
  cancelled
  failed
}

enum ScheduledPaymentFrequency {
  monthly
  quarterly
  yearly
}

model ScheduledPayment {
  id                   Int                       @id @default(autoincrement())
  scheduleRef          String                    @unique
  payerName            String
  identityNo           String
  email                String?
  zakatType            String
  financialYear        String
  amountPerInstalment  Decimal                   @db.Decimal(18, 2)
  totalInstalments     Int
  completedInstalments Int                       @default(0)
  frequency            ScheduledPaymentFrequency @default(monthly)
  cardTokenMock        String                    @default("")
  cardLast4            String                    @default("")
  cardBrand            String                    @default("")
  source               GuestPaymentSource        @default(ONLINE_GUEST)
  collectionPoint      String?
  nextChargeDate       DateTime
  status               ScheduledPaymentStatus    @default(active)
  pausedReason         String?                   @db.Text
  cancelledReason      String?                   @db.Text
  cancelledBy          Int?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  executions           ScheduledPaymentExecution[]
  cancelledByUser      User?                     @relation("ScheduledPaymentCancelledBy", fields: [cancelledBy], references: [id], onDelete: SetNull)

  @@index([identityNo, status])
  @@index([nextChargeDate, status])
  @@index([status, createdAt])
}

model ScheduledPaymentExecution {
  id                 Int               @id @default(autoincrement())
  scheduledPaymentId Int
  instalmentNo       Int
  guestPaymentId     Int               @unique
  amount             Decimal           @db.Decimal(18, 2)
  chargedAt          DateTime          @default(now())
  status             String            @default("success")
  failureReason      String?           @db.Text
  scheduledPayment   ScheduledPayment  @relation(fields: [scheduledPaymentId], references: [id], onDelete: Cascade)

  @@index([scheduledPaymentId, instalmentNo])
}

model SpgPayrollBatch {
  id                Int                      @id @default(autoincrement())
  referenceNo       String                   @unique
  employerPayerId   Int
  month             Int
  year              Int
  paymentChannel    SpgPayrollPaymentChannel
  status            SpgPayrollBatchStatus    @default(draft_preview)
  currency          String                   @default("MYR")
  totalAmount       Decimal                  @db.Decimal(18, 2)
  rowCount          Int                      @default(0)
  supportingSlipUrl String?
  officialReceiptNo String?
  submittedAt       DateTime?
  paidAt            DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  employer          PayerProfile             @relation(fields: [employerPayerId], references: [id], onDelete: Cascade)
  lines             SpgPayrollLine[]
  statusHistory     SpgPayrollStatusHistory[]
  receipt           SpgPayrollReceipt?

  @@index([employerPayerId, year, month, status])
  @@index([employerPayerId, month, year, referenceNo])
}

model SpgPayrollLine {
  id                        Int             @id @default(autoincrement())
  batchId                   Int
  employeeName              String
  employeeIdentityNo        String
  amount                    Decimal         @db.Decimal(18, 2)
  isDuplicateInFile         Boolean         @default(false)
  isDuplicateInMonthBatch   Boolean         @default(false)
  validationJson            Json?
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt
  batch                     SpgPayrollBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId, employeeIdentityNo])
}

model SpgPayrollStatusHistory {
  id        Int                   @id @default(autoincrement())
  batchId   Int
  oldStatus SpgPayrollBatchStatus?
  newStatus SpgPayrollBatchStatus
  changedBy Int?
  changedAt DateTime              @default(now())
  reason    String?               @db.Text
  batch     SpgPayrollBatch       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  changedByUser User?             @relation(fields: [changedBy], references: [id], onDelete: SetNull)

  @@index([batchId, changedAt])
}

model SpgPayrollReceipt {
  id        Int             @id @default(autoincrement())
  batchId   Int             @unique
  receiptNo String          @unique
  issuedAt  DateTime        @default(now())
  pdfUrl    String?
  batch     SpgPayrollBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// Integration 3rd Party Module (Kategori Sumber, Sumber Data, File Upload)
// -----------------------------------------------------------------------------

enum IntegrationFileType {
  ENCRYPTED_TXT
  TXT
  CSV
  EXCEL
}

enum IntegrationTransportType {
  FTP
  SFTP
  MANUAL
}

enum IntegrationStagingStatus {
  NEW
  INVALID
  DUPLICATE
  READY
  POSTED
}

enum IntegrationDuplicateType {
  SAME_FILE
  CROSS_FILE
  INTERNAL
}

enum ReconciliationMatchStatus {
  MATCHED
  DUPLICATE
  MISMATCH
  UNMATCHED
}

model IntegrationSourceCategory {
  id        Int                 @id @default(autoincrement())
  code      String              @unique @db.VarChar(30)
  name      String              @db.VarChar(100)
  isActive  Boolean             @default(true)
  notes     String?             @db.Text
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  sources   IntegrationSource[]

  @@index([code])
  @@index([isActive])
}

model IntegrationSource {
  id            Int                       @id @default(autoincrement())
  code          String                    @unique @db.VarChar(30)
  name          String                    @db.VarChar(100)
  categoryId    Int
  transportType IntegrationTransportType @default(MANUAL)
  isActive      Boolean                   @default(true)
  notes         String?                   @db.Text
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  category      IntegrationSourceCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  files         IntegrationFile[]
  configs       IntegrationConfig[]

  @@index([code])
  @@index([categoryId])
  @@index([isActive])
}

model IntegrationFile {
  id                   Int                     @id @default(autoincrement())
  sourceId             Int
  fileName             String                  @db.VarChar(255)
  filePath             String?                 @db.VarChar(500)
  fileHashSha256       String                  @unique @db.Char(64)
  receivedChannel      String                  @default("MANUAL") @db.VarChar(20)
  fileType             IntegrationFileType     @default(ENCRYPTED_TXT)
  description          String?                 @db.Text
  receivedAt           DateTime                @default(now())
  encrypted            Boolean                 @default(true)
  encryptionMethod     String?                 @db.VarChar(50)
  decryptStatus        String                  @default("PENDING") @db.VarChar(20)
  validationStatus     String                  @default("PENDING") @db.VarChar(20)
  processingStatus     String                  @default("PENDING") @db.VarChar(20)
  totalRecordsDeclared Int?
  totalAmountDeclared  Decimal?                 @db.Decimal(18, 2)
  totalRecordsParsed   Int?
  totalAmountParsed    Decimal?                 @db.Decimal(18, 2)
  errorSummary         String?                 @db.Text
  columnMappingJson    String?                 @db.Text
  aiDetectedSource     String?                 @db.VarChar(30)
  aiConfidence         Float?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  source               IntegrationSource       @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  events               IntegrationFileEvent[]
  stagingTxs            IntegrationStagingTx[]
  jobs                 IntegrationJob[]

  @@index([sourceId])
  @@index([receivedAt])
  @@index([processingStatus])
}

model IntegrationFileEvent {
  id           Int             @id @default(autoincrement())
  fileId       Int
  eventType    String          @db.VarChar(30)
  eventStatus  String          @db.VarChar(20)
  eventMessage String?         @db.Text
  createdBy    String?         @default("SYSTEM") @db.VarChar(50)
  createdAt    DateTime        @default(now())
  file         IntegrationFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([eventType])
  @@index([createdAt])
}

model IntegrationStagingTx {
  id               Int                          @id @default(autoincrement())
  fileId           Int
  sourceTxRef      String?                      @db.VarChar(80)
  payerIc          String?                      @db.VarChar(14)
  payerName        String?                      @db.VarChar(150)
  txDate           DateTime                     @db.Date
  txTime           String?                      @db.VarChar(12)
  amount           Decimal                      @db.Decimal(18, 2)
  channel          String?                      @db.VarChar(30)
  currency         String                       @default("MYR") @db.Char(3)
  recordHash       String                       @db.Char(64)
  stagingStatus    IntegrationStagingStatus     @default(NEW)
  validationErrors String?                      @db.Text
  createdAt        DateTime                     @default(now())
  file             IntegrationFile              @relation(fields: [fileId], references: [id], onDelete: Cascade)
  duplicates       IntegrationStagingDuplicate[]
  reconResults     ReconciliationResult[]

  @@unique([fileId, recordHash])
  @@index([fileId])
  @@index([payerIc, txDate, amount])
  @@index([stagingStatus])
}

model IntegrationStagingDuplicate {
  id                   Int                      @id @default(autoincrement())
  stagingTxId          Int
  duplicateType        IntegrationDuplicateType
  matchedStagingTxId    Int?
  matchedInternalTxId   String?                  @db.VarChar(36)
  reason               String?                   @db.Text
  createdAt            DateTime                 @default(now())
  stagingTx            IntegrationStagingTx      @relation(fields: [stagingTxId], references: [id], onDelete: Cascade)

  @@index([stagingTxId])
  @@index([duplicateType])
}

model IntegrationJob {
  id          Int             @id @default(autoincrement())
  fileId      Int
  jobType     String          @db.VarChar(30)
  jobStatus   String          @default("PENDING") @db.VarChar(20)
  attempt     Int             @default(0)
  maxAttempts Int             @default(5)
  lockedBy    String?         @db.VarChar(50)
  lockedAt    DateTime?
  lastError   String?         @db.Text
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  file        IntegrationFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([jobType])
  @@index([jobStatus])
}

// Bank Statement (for JAN/BANK reconciliation - MT940, CSV from banks)
model BankStatementFile {
  id           Int       @id @default(autoincrement())
  bankCode     String    @db.VarChar(20)
  bankName     String    @db.VarChar(100)
  accountNo    String    @db.VarChar(30)
  statementDate DateTime @db.Date
  importedAt   DateTime  @default(now())
  importedBy   String    @default("SYSTEM") @db.VarChar(50)
  transactions BankStatementTransaction[]

  @@index([bankCode, statementDate])
}

model BankStatementTransaction {
  id               Int       @id @default(autoincrement())
  fileId           Int
  paymentReference String?   @db.VarChar(80)
  approvalCode     String?   @db.VarChar(50)
  chequeNo         String?   @db.VarChar(20)
  valueDate        DateTime  @db.Date
  amount           Decimal   @db.Decimal(18, 2)
  description      String?   @db.VarChar(255)
  counterparty     String?   @db.VarChar(150)
  createdAt        DateTime  @default(now())
  file             BankStatementFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([paymentReference])
  @@index([valueDate, amount])
}

model ReconciliationResult {
  id              Int                    @id @default(autoincrement())
  stagingTxId     Int
  internalTxId    String?                @db.VarChar(80)
  matchStatus     ReconciliationMatchStatus
  matchRule       String?                @db.VarChar(50)
  confidenceScore Decimal?               @db.Decimal(5, 2)
  exceptionCode   String?                 @db.VarChar(30)
  exceptionDetail String?                @db.Text
  createdAt       DateTime               @default(now())
  stagingTx       IntegrationStagingTx   @relation(fields: [stagingTxId], references: [id], onDelete: Cascade)
  actions         ReconciliationAction[]
  matchLinks      ReconciliationMatchLink[]

  @@index([stagingTxId])
  @@index([matchStatus])
}

model ReconciliationMatchLink {
  id              Int       @id @default(autoincrement())
  reconResultId   Int
  internalTxId    String    @db.VarChar(80)
  amountAllocated Decimal?  @db.Decimal(18, 2)
  createdAt       DateTime  @default(now())
  reconResult     ReconciliationResult @relation(fields: [reconResultId], references: [id], onDelete: Cascade)

  @@unique([reconResultId, internalTxId])
  @@index([internalTxId])
}

model ReconciliationAction {
  id         Int                  @id @default(autoincrement())
  reconId    Int
  actionType String               @db.VarChar(30)
  actionNote String?              @db.Text
  actedBy    String               @db.VarChar(50)
  actedAt    DateTime             @default(now())
  recon      ReconciliationResult @relation(fields: [reconId], references: [id], onDelete: Cascade)

  @@index([reconId])
  @@index([actionType])
}

model IntegrationConfig {
  id            Int                @id @default(autoincrement())
  sourceId      Int?
  configKey     String             @db.VarChar(80)
  configValue   String             @db.Text
  isSecret      Boolean            @default(false)
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  updatedBy     String?            @default("SYSTEM") @db.VarChar(50)
  updatedAt     DateTime           @updatedAt
  source        IntegrationSource? @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([configKey])
}
